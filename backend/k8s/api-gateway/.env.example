# =============================================================================
# API Gateway (Kubernetes) — Environment Configuration
# =============================================================================
# Copy this file to `.env` (in this directory) to configure for Minikube/K8s.
#   cp .env.example .env
# =============================================================================

APP_PORT=8080

REDIS_HOST=host.minikube.internal
REDIS_PORT=6380
REDIS_PASSWORD=redis_password

CLIENT_URL=http://host.minikube.internal:3000

SPRING_SECURITY_USER_NAME=admin
SPRING_SECURITY_USER_PASSWORD=admin

USER_SERVICE_URI=http://user-service:8080
FOOD_SERVICE_URI=http://food-service:8080

JWK_SET_URI=http://user-service:8080/.well-known/jwks.json
