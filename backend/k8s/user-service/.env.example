# =============================================================================
# User Service (Kubernetes) — Environment Configuration
# =============================================================================
# Copy this file to `.env` (in this directory) to configure for Minikube/K8s.
#   cp .env.example .env
# =============================================================================

APP_PORT=8080

POSTGRES_HOST=host.minikube.internal
POSTGRES_PORT=5433
POSTGRES_DB=db_user_name
POSTGRES_USER=db_user_user
POSTGRES_PASSWORD=db_user_password

REDIS_HOST=host.minikube.internal
REDIS_PORT=6381
REDIS_PASSWORD=redis_password

RABBITMQ_HOST=host.minikube.internal
RABBITMQ_PORT=5672
RABBITMQ_USER=salob
RABBITMQ_PASSWORD=rabbitmq_password
RABBITMQ_VHOST=salob

# MinIO / S3-compatible storage
MINIO_ENDPOINT=http://host.minikube.internal:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change_me_minio
MINIO_BUCKET=user-service-bucket
MINIO_REGION=us-east-1
MINIO_USE_SSL=false
MINIO_FORCE_PATH_STYLE=true

GRPC_PORT=9090
FOOD_SERVICE_GRPC_ADDRESS=dns:///food-service:9090

JWT_KEY_ALIAS=salob-key
JWT_KEYSTORE_PASSWORD=password
JWT_EXPIRATION_SECONDS=3600
