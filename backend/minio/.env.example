# =============================================================================
# MinIO — Environment Configuration
# =============================================================================
# Copy this file to `.env` and fill in any blanks below.
#   cp .env.example .env
#
# The values below are safe development defaults. For production, replace
# secrets (passwords, keys, tokens) with real values in your `.env` file
# (which is gitignored — never commit secrets).
# =============================================================================

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_minio

# Buckets created automatically on startup
MINIO_BUCKET_FOOD=food-service-bucket
MINIO_BUCKET_USER=user-service-bucket

# Optional: if you run behind a reverse proxy or want explicit public URLs
# MINIO_SERVER_URL=http://localhost:9000
# MINIO_BROWSER_REDIRECT_URL=http://localhost:9001
