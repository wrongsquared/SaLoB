# API base URL. Defaults to /api (proxied to localhost:8081 via Vite in dev).
# Override for production or when running backend on a different host.
# VITE_API_BASE_URL=/api

# Enable MSW (Mock Service Worker) in development for offline testing.
# Set to 'true' to intercept all API requests with mocks.
# VITE_ENABLE_MSW=false
